# Release signing for Google Play — copy to `keystore.properties` (which is
# gitignored) and fill in your real values. Never commit the real file or the
# .jks keystore.
#
# 1. Generate your upload key (choose strong passwords when prompted):
#      keytool -genkey -v -keystore ~/investikid-upload.jks \
#        -keyalg RSA -keysize 2048 -validity 10000 -alias investikid-upload
# 2. Copy this file:  cp keystore.properties.example keystore.properties
# 3. Fill in the values below.
# 4. Build the bundle:  ./gradlew :app:bundleRelease
#      → output: app/build/outputs/bundle/release/app-release.aab

# Absolute path to your keystore (recommended), or a path relative to android/.
storeFile=/Users/leeashmore/investikid-upload.jks
storePassword=CHANGE_ME
keyAlias=investikid-upload
keyPassword=CHANGE_ME
